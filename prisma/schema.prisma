generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "template"]
}

model SuperAdmin {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  email      String   @unique
  password   String
  is_active  Boolean  @default(false)
  created_at DateTime @default(now())

  refreshTokens RefreshToken[]

  @@index([username], map: "idx_superadmin_username")
  @@index([email], map: "idx_superadmin_email")
  @@schema("public")
}

model University {
  id               Int                 @id @default(autoincrement())
  name             String              @unique
  address          String?
  phone            String?
  email            String?
  website          String?
  established_date DateTime?
  accreditation    String?
  db_schema        String              @unique
  is_active        Boolean             @default(false)
  created_at       DateTime            @default(now())
  updated_at       DateTime            @default(now())
  settings         UniversitySettings?

  @@schema("public")
}

model UniversitySettings {
  id              Int        @id @default(autoincrement())
  university_id   Int        @unique
  primary_color   String     @default("#2563eb")
  secondary_color String     @default("#7c3aed")
  tab_name        String?
  logo_url        String?
  hero_images     String[]   @default([])
  updated_at      DateTime   @updatedAt
  university      University @relation(fields: [university_id], references: [id], onDelete: Cascade)

  @@schema("public")
}

model RefreshToken {
  id             Int        @id @default(autoincrement())
  super_admin_id Int
  token          String     @unique
  expires_at     DateTime
  is_revoked     Boolean    @default(false)
  created_at     DateTime   @default(now())
  updated_at     DateTime
  SuperAdmin     SuperAdmin @relation(fields: [super_admin_id], references: [id], onDelete: Cascade)

  @@index([expires_at])
  @@index([super_admin_id])
  @@schema("public")
}

model Job {
  id            String    @id @default(uuid()) @db.Uuid
  file_url      String    @db.VarChar(512)
  status        JobStatus @default(Pending)
  total_rows    Int?
  inserted_rows Int?
  failed_rows   Int?
  error_log     Json?
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  started_at    DateTime? @db.Timestamptz(6)
  completed_at  DateTime? @db.Timestamptz(6)

  @@index([status])
  @@index([created_at])
  @@schema("template")
}

model EnrollmentJob {
  id         String              @id @default(uuid()) @db.Uuid
  studentId  Int                 @map("student_id")
  semesterId Int                 @map("semester_id")
  status     EnrollmentJobStatus @default(Pending)
  result     Json? // per-slot outcomes written by worker
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  student  Student  @relation(fields: [studentId], references: [userId])
  semester Semester @relation(fields: [semesterId], references: [id])

  @@index([studentId, semesterId])
  @@index([status])
  @@map("EnrollmentJob")
  @@schema("template")
}

model User {
  id                        Int                        @id @default(autoincrement())
  username                  String                     @unique @db.VarChar(100)
  firstName                 String                     @map("first_name") @db.VarChar(100)
  lastName                  String                     @map("last_name") @db.VarChar(100)
  email                     String                     @unique @db.VarChar(320)
  password                  String                     @db.VarChar(60)
  isVerified                Boolean                    @default(false) @map("is_verified")
  isBlocked                 Boolean                    @default(false) @map("is_blocked")
  blockReason               BlockReasonType?
  phone                     String                     @db.VarChar(15)
  dateOfBirth               DateTime                   @map("date_of_birth") @db.Date
  address                   String
  city                      String                     @db.VarChar(100)
  country                   String                     @db.VarChar(100)
  nationalId                String                     @unique @map("national_id") @db.VarChar(50)
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")
  LearningGroupMembers      LearningGroupMember[]
  LearningGroupPostsAuthor  LearningGroupPost[]
  LearningGroupPostComments LearningGroupPostComment[]
  staff                     Staff?
  student                   Student?
  userRoles                 UserRole[]
  announcements             Announcement[]

  @@index([email])
  @@index([username])
  @@index([nationalId])
  @@map("User")
  @@schema("template")
}

model Announcement {
  id      Int    @id @default(autoincrement())
  title   String @db.VarChar(300)
  content String

  type     AnnouncementType     @default(ANNOUNCEMENT)
  audience AnnouncementAudience @default(ALL)
  status   AnnouncementStatus   @default(PUBLISHED)

  eventDate     DateTime? @map("event_date")
  eventLocation String?   @map("event_location") @db.VarChar(300)

  authorId Int @map("author_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author User @relation(fields: [authorId], references: [id])

  @@index([type])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("Announcement")
  @@schema("template")
}

model Staff {
  userId Int  @id @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  position String   @db.VarChar(100)
  cvPath   String?  @map("cv_path") @db.VarChar(1000)
  hireDate DateTime @map("hire_date") @db.Date
  salary   Decimal? @db.Decimal(12, 2)

  attendanceSessions AttendanceSession[]
  ScheduleSlots      ScheduleSlot[]

  programStaffs   ProgramStaff[]
  headedPrograms  Program[]      @relation("ProgramHead") // tells which programs he is the head of
  deanOfFaculties Faculty[]

  @@index([position])
  @@map("Staff")
  @@schema("template")
}

model Faculty {
  id              Int            @id @default(autoincrement())
  universityId    Int            @map("university_id")
  name            String         @db.VarChar(255)
  description     String?
  deanId          Int?           @map("dean_id")
  establishedDate DateTime?      @map("established_date") @db.Date
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  dean            Staff?         @relation(fields: [deanId], references: [userId])
  programs        Program[]
  regulations     Regulation[]
  programStaffs   ProgramStaff[]

  @@index([universityId])
  @@index([name])
  @@index([deanId])
  @@map("Faculty")
  @@schema("template")
}

model Program {
  id                    Int      @id @default(autoincrement())
  facultyId             Int      @map("faculty_id")
  name                  String   @db.VarChar(255)
  description           String?
  headId                Int?     @map("head_id")
  phone                 String?  @db.VarChar(20)
  universityCreditHours Int      @default(0) @map("university_credit_hours")
  facultyCreditHours    Int      @default(0) @map("faculty_credit_hours")
  programCreditHours    Int      @default(0) @map("program_credit_hours")
  durationYears         Int?     @map("duration_years")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  head    Staff?  @relation(fields: [headId], references: [userId], name: "ProgramHead")
  faculty Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  programType   ProgramType       @map("program_type")
  resultDisplay ResultDisplayType @default(CourseGrade) @map("result_display")

  academicLoadGPAs      AcademicLoadGPA[]
  academicLoadSemesters AcademicLoadSemester[]
  programCourses        ProgramCourse[]
  programLevels         ProgramLevel[]
  programTranscriptDefs ProgramTranscriptDefinition[]
  students              Student[]
  programStaffs         ProgramStaff[]
  scheduleSlotContexts  ScheduleSlotContext[]

  @@unique([name])
  @@index([facultyId])
  @@index([programType])
  @@index([headId])
  @@map("Program")
  @@schema("template")
}

model ProgramStaff {
  id Int @id @default(autoincrement())

  staffId Int   @map("staff_id")
  staff   Staff @relation(fields: [staffId], references: [userId], onDelete: Cascade)

  programId Int     @map("program_id")
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  // Denormalization: This allows us to say "Give me all staff in this Faculty"
  // without jumping through the Program table.
  facultyId Int     @map("faculty_id")
  faculty   Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@unique([staffId, programId])
  @@index([facultyId, staffId]) // Added for "Teacher-in-Faculty" lookups
  @@map("ProgramStaff")
  @@schema("template")
}

model Student {
  userId                Int                  @id @map("user_id")
  universityStudentId   Int                  @unique @map("university_student_id")
  programId             Int                  @map("program_id")
  status                StudentStatus        @default(New)
  enrollmentDate        DateTime             @map("enrollment_date") @db.Date
  cgpa                  Decimal              @default(0.0000) @db.Decimal(5, 4)
  homePhone             String?              @map("home_phone") @db.VarChar(20)
  previousQualification String?              @map("previous_qualification") @db.VarChar(255)
  secondarySchoolName   String?              @map("secondary_school_name") @db.VarChar(255)
  totalHighSchoolGrades Decimal?             @map("total_high_school_grades") @db.Decimal(5, 2)
  highSchoolSeatNumber  String?              @map("high_school_seat_number") @db.VarChar(50)
  programLevelId        Int                  @map("program_level_id")
  religion              String               @db.Char(1)
  gender                String               @db.Char(1)
  fullname              String?              @db.VarChar(100)
  attendanceReports     AttendanceReport[]
  courseRegistrations   CourseRegistration[]
  program               Program              @relation(fields: [programId], references: [id])
  programLevel          ProgramLevel         @relation(fields: [programLevelId, programId], references: [id, programId])
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentAttendances    StudentAttendance[]
  studentFeeReports     StudentFeeReport[]
  transcripts           Transcript[]
  enrollmentJobs        EnrollmentJob[]

  @@index([programId])
  @@index([status])
  @@index([universityStudentId])
  @@map("Student")
  @@schema("template")
}

model Regulation {
  id                   Int         @id @default(autoincrement())
  facultyId            Int         @map("faculty_id")
  name                 String      @db.VarChar(255)
  roundToWholeNumber   Boolean     @default(false) @map("round_to_whole_number")
  approximateFractions Boolean     @default(false) @map("approximate_fractions")
  maxAbsence           Int         @default(0) @map("max_absence")
  minGradeExcellent    Decimal     @map("min_grade_excellent") @db.Decimal(5, 2)
  minGradeVeryGood     Decimal     @map("min_grade_very_good") @db.Decimal(5, 2)
  minGradeGood         Decimal     @map("min_grade_good") @db.Decimal(5, 2)
  minGradeAcceptable   Decimal     @map("min_grade_acceptable") @db.Decimal(5, 2)
  minGradeVeryWeak     Decimal     @map("min_grade_very_weak") @db.Decimal(5, 2)
  enableMercyRules     Boolean     @default(false) @map("enable_mercy_rules")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")
  mercyRules           MercyRule[]
  faculty              Faculty     @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@index([facultyId])
  @@map("Regulation")
  @@schema("template")
}

model MercyRule {
  id            Int        @id @default(autoincrement())
  regulationId  Int        @map("regulation_id")
  originalScore Decimal    @map("original_score") @db.Decimal(5, 2)
  adjustedScore Decimal    @map("adjusted_score") @db.Decimal(5, 2)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  regulation    Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)

  @@index([regulationId])
  @@map("MercyRule")
  @@schema("template")
}

model Semester {
  id                  Int                  @id @default(autoincrement())
  year                Int                  @db.SmallInt
  term                Int                  @db.SmallInt
  startDate           DateTime             @map("start_date") @db.Date
  endDate             DateTime             @map("end_date") @db.Date
  type                SemesterType
  scheduleSlots       ScheduleSlot[]
  courseRegistrations CourseRegistration[]
  studentFeeReports   StudentFeeReport[]
  transcripts         Transcript[]
  courseAssessments   CourseAssessment[]
  enrollmentJobs      EnrollmentJob[]
  learningGroups      LearningGroup[]
  transcriptJobs      TranscriptJob[]

  @@unique([year, term])
  @@index([year])
  @@map("Semester")
  @@schema("template")
}

model ProgramLevel {
  id                    Int                    @id @default(autoincrement())
  programId             Int                    @map("program_id")
  level                 Int
  minCredits            Int                    @default(0) @map("min_credits")
  maxCredits            Int                    @default(0) @map("max_credits")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  academicLoadSemesters AcademicLoadSemester[]
  fees                  Fee[]
  program               Program                @relation(fields: [programId], references: [id], onDelete: Cascade)
  student               Student[]
  studentFeeReports     StudentFeeReport[]
  programCourses        ProgramCourse[]

  @@unique([programId, level])
  @@unique([id, programId])
  @@index([programId])
  @@map("ProgramLevel")
  @@schema("template")
}

model Fee {
  id                Int                @id @default(autoincrement())
  programLevelId    Int                @map("program_level_id")
  semesterNumber    Int                @map("semester_number") @db.SmallInt
  feeType           FeeType            @map("fee_type")
  amount            Decimal            @db.Decimal(12, 2)
  description       String?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  programLevel      ProgramLevel       @relation(fields: [programLevelId], references: [id], onDelete: Cascade)
  studentFeeReports StudentFeeReport[]

  @@unique([programLevelId, semesterNumber, feeType])
  @@index([semesterNumber])
  @@index([feeType])
  @@map("Fee")
  @@schema("template")
}

model ProgramTranscriptDefinition {
  id                 Int       @id @default(autoincrement())
  programId          Int       @map("program_id")
  gradeLetter        GradeEnum @map("grade_letter")
  minScore           Decimal   @map("min_score") @db.Decimal(5, 2)
  maxScore           Decimal   @map("max_score") @db.Decimal(5, 2)
  equivalentEstimate String?   @map("equivalent_estimate") @db.VarChar(20)
  minGpa             Decimal   @map("min_gpa") @db.Decimal(5, 4)
  maxGpa             Decimal   @map("max_gpa") @db.Decimal(5, 4)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  program            Program   @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, gradeLetter])
  @@index([programId])
  @@map("ProgramTranscriptDefinition")
  @@schema("template")
}

model AcademicLoadSemester {
  id             Int          @id @default(autoincrement())
  programId      Int          @map("program_id")
  semesterNumber Int          @map("semester_number") @db.SmallInt
  programLevelId Int          @map("program_level_id")
  minCredits     Int          @map("min_credits")
  maxCredits     Int          @map("max_credits")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  program        Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  programLevel   ProgramLevel @relation(fields: [programLevelId], references: [id], onDelete: Cascade)

  @@unique([programId, semesterNumber, programLevelId])
  @@index([semesterNumber])
  @@map("AcademicLoadSemester")
  @@schema("template")
}

model AcademicLoadGPA {
  id         Int      @id @default(autoincrement())
  programId  Int      @map("program_id")
  minGpa     Decimal  @map("min_gpa") @db.Decimal(5, 4)
  maxGpa     Decimal  @map("max_gpa") @db.Decimal(5, 4)
  minCredits Int      @map("min_credits")
  maxCredits Int      @map("max_credits")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
  @@map("AcademicLoadGPA")
  @@schema("template")
}

model Course {
  id                        Int                  @id @default(autoincrement())
  name                      String               @db.VarChar(255)
  code                      String               @unique @db.VarChar(20)
  description               String?
  credits                   Int
  syllabus                  String?
  successPercentage         Decimal?             @map("success_percentage") @db.Decimal(5, 2)
  totalFail                 Boolean              @default(false) @map("total_fail")
  minFinalSuccessPercentage Decimal?             @map("min_final_success_percentage") @db.Decimal(5, 2)
  createdAt                 DateTime             @default(now()) @map("created_at")
  updatedAt                 DateTime             @updatedAt @map("updated_at")
  attendanceReports         AttendanceReport[]
  prerequisites             CoursePrerequisite[] @relation("course")
  requiredBy                CoursePrerequisite[] @relation("prerequisite")
  programCourses            ProgramCourse[]
  courseAssessments         CourseAssessment[]
  scheduleSlots             ScheduleSlot[]
  learningGroups            LearningGroup[]

  @@index([name])
  @@index([code, name])
  @@map("Course")
  @@schema("template")
}

model Classroom {
  id               Int           @id @default(autoincrement())
  classroomNumber  String        @map("classroom_number") @db.VarChar(50)
  building         String        @db.VarChar(100)
  capacity         Int
  type             ClassroomType
  underMaintenance Boolean       @default(false)

  scheduleSlot ScheduleSlot[]

  @@unique([classroomNumber, building])
  @@index([building])
  @@index([underMaintenance])
  @@map("Classroom")
  @@schema("template")
}

model LearningGroup {
  id                Int      @id @default(autoincrement())
  courseId          Int      @map("course_id")
  semesterId        Int      @map("semester_id")
  groupName         String   @map("group_name") @db.VarChar(255)
  accessCode        String?  @map("access_code") @db.VarChar(50)
  allowStudentPosts Boolean  @default(false) @map("allow_student_posts")
  createdAt         DateTime @default(now()) @map("created_at")

  course   Course                @relation(fields: [courseId], references: [id])
  semester Semester              @relation(fields: [semesterId], references: [id])
  members  LearningGroupMember[]
  posts    LearningGroupPost[]

  @@unique([courseId, semesterId]) // one group per course per semester
  @@index([semesterId])
  @@map("LearningGroup")
  @@schema("template")
}

model ScheduleSlot {
  id          Int @id @default(autoincrement())
  teacherId   Int @map("teacher_id")
  courseId    Int @map("course_id")
  classroomId Int @map("classroom_id")
  semesterId  Int @map("semester_id")

  dayOfWeek       DayOfWeek @map("day_of_week")
  startTime       DateTime  @map("start_time") @db.Time(6)
  endTime         DateTime  @map("end_time") @db.Time(6)
  type            SlotType  @default(Lecture)
  allowedCapacity Int       @db.SmallInt

  // This tracks the total physical people in the room across ALL programs
  enrolledSeats Int @default(0) @map("enrolled_seats") @db.SmallInt

  // Relations
  teacher   Staff     @relation(fields: [teacherId], references: [userId])
  course    Course    @relation(fields: [courseId], references: [id])
  semester  Semester  @relation(fields: [semesterId], references: [id])
  classroom Classroom @relation(fields: [classroomId], references: [id])

  slotContext        ScheduleSlotContext[]
  attendanceSessions AttendanceSession[]

  @@unique([semesterId, teacherId, classroomId, dayOfWeek, startTime, endTime])
  @@index([semesterId, dayOfWeek]) // Fast loading of a full semester timetable
  @@index([classroomId, dayOfWeek])
  @@index([teacherId, semesterId])
  @@map("ScheduleSlot")
  @@schema("template")
}

model ScheduleSlotContext {
  id            Int @id @default(autoincrement())
  slotId        Int @map("slot_id")
  programId     Int @map("program_id")
  academicLevel Int @map("academic_level")
  semesterId    Int @map("semester_id")

  // Relations
  slot          ScheduleSlot         @relation(fields: [slotId], references: [id], onDelete: Cascade)
  program       Program              @relation(fields: [programId], references: [id], onDelete: Cascade)
  registrations CourseRegistration[]

  @@unique([semesterId, slotId, programId])
  @@index([slotId])
  @@index([semesterId, programId, academicLevel])
  @@map("ScheduleSlotContext")
  @@schema("template")
}

model CourseAssessment {
  id             Int                  @id @default(autoincrement())
  courseId       Int                  @map("course_id")
  semesterId     Int                  @map("semester_id")
  label          String               @db.VarChar(100)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  assessmentType CourseAssessmentType @map("assessment_type")
  marks          Decimal              @db.Decimal(5, 2)

  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  semester Semester @relation(fields: [semesterId], references: [id])
  grades   Grade[]

  @@index([courseId, semesterId])
  @@index([assessmentType])
  @@map("CourseAssessment")
  @@schema("template")
}

model ProgramCourse {
  id Int @id @default(autoincrement())

  programId Int
  program   Program @relation(fields: [programId], references: [id])

  programLevelId Int          @map("program_level_id")
  programLevel   ProgramLevel @relation(fields: [programLevelId], references: [id], onDelete: Cascade)

  courseId Int    @map("course_id")
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  type CourseType

  @@unique([programLevelId, courseId])
  @@index([programId])
  @@index([courseId])
  @@index([type])
  @@map("ProgramCourse")
  @@schema("template")
}

model CoursePrerequisite {
  courseId       Int    @map("course_id")
  prerequisiteId Int    @map("prerequisite_id")
  course         Course @relation("course", fields: [courseId], references: [id], onDelete: Cascade)
  prerequisite   Course @relation("prerequisite", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  // this optimizes what are the prerequisites for this course 
  @@id([courseId, prerequisiteId])
  // This allows the DB to find 'requiredBy' courses without a table lookup.
  @@index([prerequisiteId, courseId])
  @@map("CoursePrerequisite")
  @@schema("template")
}

model StudentFeeReport {
  id             Int          @id @default(autoincrement())
  studentId      Int          @map("student_id")
  programLevelId Int          @map("program_level_id")
  semesterId     Int          @map("semester_id")
  feeId          Int          @map("fee_id")
  amount         Decimal      @db.Decimal(12, 2)
  status         FeeStatus    @default(Pending)
  generatedDate  DateTime     @default(now()) @map("generated_date") @db.Date
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  fee            Fee          @relation(fields: [feeId], references: [id])
  programLevel   ProgramLevel @relation(fields: [programLevelId], references: [id])
  semester       Semester     @relation(fields: [semesterId], references: [id])
  student        Student      @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@index([studentId])
  @@index([semesterId])
  @@index([status])
  @@map("StudentFeeReport")
  @@schema("template")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique @db.VarChar(100)
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  permissions RolePermission[]
  userRoles   UserRole[]

  @@index([name])
  @@map("Role")
  @@schema("template")
}

model Permission {
  id              Int              @id @default(autoincrement())
  name            String           @unique @db.VarChar(100)
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@index([name])
  @@map("Permission")
  @@schema("template")
}

model UserRole {
  userId     Int      @map("user_id")
  roleId     Int      @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("UserRole")
  @@schema("template")
}

model RolePermission {
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("RolePermission")
  @@schema("template")
}

model CourseRegistration {
  id                  Int                  @id @default(autoincrement())
  studentId           Int                  @map("student_id")
  semesterId          Int                  @map("semester_id")
  enrollmentDate      DateTime             @default(now()) @map("enrollment_date") @db.Date
  status              RegistrationStatus   @default(Enrolled)
  grade               GradeEnum?
  gradePoints         Int?                 @map("grade_points")
  semester            Semester             @relation(fields: [semesterId], references: [id])
  student             Student              @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  grades              Grade[]
  slotContextId       Int?                 @map("slot_context_Id")
  scheduleSlotContext ScheduleSlotContext? @relation(fields: [slotContextId], references: [id])

  @@unique([studentId, slotContextId, semesterId])
  @@index([studentId])
  @@index([slotContextId])
  @@index([semesterId])
  @@index([status])
  @@map("CourseRegistration")
  @@schema("template")
}

model Grade {
  id                   Int                @id @default(autoincrement())
  courseRegistrationId Int                @map("course_registration_id")
  courseAssessmentId   Int                @map("course_assessment_id")
  marks                Decimal            @db.Decimal(5, 2)
  maxMarks             Decimal            @map("max_marks") @db.Decimal(5, 2)
  assessmentDate       DateTime?          @map("assessment_date") @db.Date
  comments             String?
  courseAssessment     CourseAssessment   @relation(fields: [courseAssessmentId], references: [id], onDelete: Cascade)
  courseRegistration   CourseRegistration @relation(fields: [courseRegistrationId], references: [id], onDelete: Cascade)

  @@index([courseRegistrationId])
  @@index([courseAssessmentId])
  @@map("Grade")
  @@schema("template")
}

model Transcript {
  id            Int      @id @default(autoincrement())
  studentId     Int      @map("student_id")
  semesterId    Int      @map("semester_id")
  year          Int
  semesterGpa   Decimal  @map("semester_gpa") @db.Decimal(5, 4)
  cumulativeGpa Decimal  @map("cumulative_gpa") @db.Decimal(5, 4)
  totalCredits  Int      @default(0) @map("total_credits")
  generatedDate DateTime @default(now()) @map("generated_date") @db.Date
  semester      Semester @relation(fields: [semesterId], references: [id])
  student       Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@unique([studentId, semesterId])
  @@index([studentId])
  @@index([semesterId])
  @@index([year])
  @@map("Transcript")
  @@schema("template")
}

model TranscriptJob {
  id         String              @id @default(uuid()) @db.Uuid
  facultyId  Int                 @map("faculty_id")
  semesterId Int                 @map("semester_id")
  status     TranscriptJobStatus @default(Pending)
  result     Json?
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  semester Semester @relation(fields: [semesterId], references: [id])

  @@index([semesterId])
  @@index([status])
  @@map("TranscriptJob")
  @@schema("template")
}

model AttendanceSession {
  id              Int            @id @default(autoincrement())
  scheduleSlotId  Int            @map("schedule_slot_id")
  facultyMemberId Int            @map("faculty_member_id")
  sessionDate     DateTime       @map("session_date") @db.Date
  startTime       DateTime       @map("start_time") @db.Time(6)
  endTime         DateTime       @map("end_time") @db.Time(6)
  attendanceMode  AttendanceMode @map("attendance_mode")
  hotspotSsid     String?        @map("hotspot_ssid") @db.VarChar(255)
  qrCode          String?        @map("qr_code") @db.VarChar(500)
  createdAt       DateTime       @default(now()) @map("created_at")
  sessionNotes    String?        @map("session_notes")

  scheduleSlot  ScheduleSlot        @relation(fields: [scheduleSlotId], references: [id], onDelete: Cascade)
  facultyMember Staff               @relation(fields: [facultyMemberId], references: [userId])
  attendance    StudentAttendance[]

  @@index([scheduleSlotId, sessionDate])
  @@index([sessionDate])
  @@map("AttendanceSession")
  @@schema("template")
}

model StudentAttendance {
  id                  Int               @id @default(autoincrement())
  attendanceSessionId Int               @map("attendance_session_id")
  studentId           Int               @map("student_id")
  status              AttendanceStatus
  recordedAt          DateTime          @default(now()) @map("recorded_at")
  deviceIp            String?           @map("device_ip") @db.Inet
  deviceMac           String?           @map("device_mac") @db.VarChar(17)
  notes               String?
  isOfflineSync       Boolean           @default(false) @map("is_offline_sync")
  syncedAt            DateTime?         @map("synced_at")
  attendanceSession   AttendanceSession @relation(fields: [attendanceSessionId], references: [id], onDelete: Cascade)
  student             Student           @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@unique([attendanceSessionId, studentId])
  @@index([attendanceSessionId])
  @@index([studentId])
  @@index([status])
  @@index([recordedAt])
  @@map("StudentAttendance")
  @@schema("template")
}

model AttendanceReport {
  id                   Int      @id @default(autoincrement())
  courseId             Int      @map("course_id")
  studentId            Int      @map("student_id")
  totalSessions        Int      @default(0) @map("total_sessions")
  attendedSessions     Int      @default(0) @map("attended_sessions")
  attendancePercentage Decimal  @map("attendance_percentage") @db.Decimal(5, 2)
  reportPeriodStart    DateTime @map("report_period_start") @db.Date
  reportPeriodEnd      DateTime @map("report_period_end") @db.Date
  generatedAt          DateTime @default(now()) @map("generated_at")
  course               Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student              Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@unique([courseId, studentId, reportPeriodStart, reportPeriodEnd])
  @@index([courseId])
  @@index([studentId])
  @@index([reportPeriodStart, reportPeriodEnd])
  @@map("AttendanceReport")
  @@schema("template")
}

model LearningGroupMember {
  learningGroupId Int               @map("learning_group_id")
  userId          Int               @map("user_id")
  role            LearningGroupRole @default(Member)
  joinedAt        DateTime          @default(now()) @map("joined_at")

  group LearningGroup @relation(fields: [learningGroupId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([learningGroupId, userId])
  @@index([userId])
  @@map("LearningGroupMember")
  @@schema("template")
}

model LearningGroupPost {
  id              Int       @id @default(autoincrement())
  learningGroupId Int       @map("learning_group_id")
  authorId        Int       @map("author_id")
  postType        PostType  @map("post_type")
  content         String?
  dueDate         DateTime? @map("due_date")
  isPinned        Boolean   @default(false) @map("is_pinned")
  isEdited        Boolean   @default(false) @map("is_edited")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  learningGroup LearningGroup                 @relation(fields: [learningGroupId], references: [id], onDelete: Cascade)
  author        User                          @relation(fields: [authorId], references: [id])
  attachments   LearningGroupPostAttachment[]
  comments      LearningGroupPostComment[]

  @@index([learningGroupId, postType])
  @@index([authorId])
  @@map("LearningGroupPost")
  @@schema("template")
}

model LearningGroupPostAttachment {
  id              Int             @id @default(autoincrement())
  postId          Int             @map("post_id")
  fileName        String          @map("file_name") @db.VarChar(255)
  fileType        String          @map("file_type") @db.VarChar(50)
  storageProvider StorageProvider @map("storage_provider")
  storagePath     String          @map("storage_path") @db.VarChar(500)
  fileSize        BigInt?         @map("file_size")
  uploadedAt      DateTime        @default(now()) @map("uploaded_at")

  post LearningGroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("LearningGroupPostAttachment")
  @@schema("template")
}

model LearningGroupPostComment {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  authorId  Int      @map("author_id")
  content   String
  isEdited  Boolean  @default(false) @map("is_edited") // added for consistency with posts
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post   LearningGroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User              @relation(fields: [authorId], references: [id])

  @@index([postId])
  @@index([authorId])
  @@map("LearningGroupPostComment")
  @@schema("template")
}

