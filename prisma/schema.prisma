generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SuperAdmin {
  id         Int       @id @default(autoincrement())
  username   String    @unique
  email      String    @unique
  password   String
  is_active  Boolean   @default(false)
  created_at DateTime  @default(now())

  @@index([username], map: "idx_superadmin_username")
  @@index([email], map: "idx_superadmin_email")
}

model University {
  id               Int       @id @default(autoincrement())
  name             String    @unique
  address          String?
  phone            String?
  email            String?
  website          String?
  established_date DateTime?
  accreditation    String?
  db_schema        String    @unique
  is_active        Boolean   @default(false)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now())
}

// ============================================================================================================
// ENUMS
// ============================================================================================================

enum ProgramType {
  Bachelor
  Master
  Diploma
  PhD
}

enum ResultDisplayType {
  CourseGrade
  DetailedEstimate
}

enum BlockReasonType {
  NonPaymentCurrent
  NonPaymentOld
}

enum StudentStatus {
  New
  Repeat
  SingleChance
  ExternalReenrollment
  Deactivate
}

enum SemesterType {
  Fall
  Spring
  Summer
  Winter
}

enum FeeType {
  ConstantYear
  ConstantSemester
  PerCreditHour
  PerCourse
  Administrative
  Other
}

enum CourseAssessmentType {
  Quiz
  Assignment
  Midterm
  Final
  Project
}

enum CourseType {
  Mandatory
  Elective
  Project
}

enum FeeStatus {
  Pending
  Paid
}

enum ClassroomType {
  Lecture
  Lab
  Auditorium
  Other
}

enum DayOfWeek {
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
  Sunday
}

enum RegistrationStatus {
  Enrolled
  Withdrawn
  Completed
  Failed
  InProgress
}

enum GradeEnum {
  A_PLUS @map("A+")
  A
  A_MINUS @map("A-")
  B_PLUS @map("B+")
  B
  B_MINUS @map("B-")
  C_PLUS @map("C+")
  C
  C_MINUS @map("C-")
  D_PLUS @map("D+")
  D
  F
}

enum AttendanceMode {
  Manual
  QRCode
  Biometric
  Geofencing
  Hotspot
  Online
}

enum AttendanceStatus {
  Present
  Absent
  Late
  Excused
  Medical
}

enum RoomRole {
  Owner
  Member
}

enum PostType {
  ANNOUNCEMENT
  ASSIGNMENT
  MATERIAL
}

enum StorageProvider {
  LOCAL
  S3
  Azure_Blob_Storage @map("Azure Blob Storage")
  Google_Cloud_Storage @map("Google Cloud Storage")
}

// ============================================================================================================
// USER
// ============================================================================================================

model User {
  id             Int       @id @default(autoincrement())
  username       String    @unique @db.VarChar(100)
  firstName      String    @map("first_name") @db.VarChar(100)
  lastName       String    @map("last_name") @db.VarChar(100)
  email          String    @unique @db.VarChar(320)
  password       String    @db.VarChar(60)
  isVerified     Boolean   @default(false) @map("is_verified")
  isBlocked      Boolean   @default(false) @map("is_blocked")
  phone          String    @db.VarChar(15)
  dateOfBirth    DateTime  @map("date_of_birth") @db.Date
  address        String
  city           String    @db.VarChar(100)
  country        String    @db.VarChar(100)
  nationalId     String    @unique @map("national_id") @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  staff             Staff?
  student           Student?
  userRoles         UserRole[]
  roomsCreated      Room[]
  roomMembers       RoomMember[]
  roomPostsAuthor   RoomPost[]
  roomPostComments  RoomPostComment[]

  @@index([email])
  @@index([username])
  @@index([nationalId])
  @@map("User")
}

// ============================================================================================================
// STAFF
// ============================================================================================================

model Staff {
  userId    Int       @id @map("user_id")
  position  String    @db.VarChar(100)
  cvPath    String?   @map("cv_path") @db.VarChar(1000)
  hireDate  DateTime  @map("hire_date") @db.Date
  salary    Decimal?  @db.Decimal(12, 2)

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  faculties         Faculty[]
  programs          Program[]
  classSessions     ClassSession[]
  attendanceSessions AttendanceSession[]

  @@index([position])
  @@map("Staff")
}

// ============================================================================================================
// FACULTY
// ============================================================================================================

model Faculty {
  id                Int       @id @default(autoincrement())
  universityId      Int       @map("university_id")
  name              String    @db.VarChar(255)
  description       String?
  deanId            Int?      @map("dean_id")
  establishedDate   DateTime? @map("established_date") @db.Date
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  dean              Staff?    @relation(fields: [deanId], references: [userId], onDelete: SetNull)
  programs          Program[]
  regulations       Regulation[]

  @@index([universityId])
  @@index([name])
  @@index([deanId])
  @@map("Faculty")
}

// ============================================================================================================
// PROGRAM
// ============================================================================================================

model Program {
  id                        Int               @id @default(autoincrement())
  facultyId                 Int               @map("faculty_id")
  name                      String            @db.VarChar(255)
  description               String?
  headId                    Int?              @map("head_id")
  phone                     String?           @db.VarChar(20)
  universityCreditHours     Int               @default(0) @map("university_credit_hours")
  facultyCreditHours        Int               @default(0) @map("faculty_credit_hours")
  programCreditHours        Int               @default(0) @map("program_credit_hours")
  programType               ProgramType       @map("program_type")
  resultDisplay             ResultDisplayType @default(CourseGrade) @map("result_display")
  blockReason               BlockReasonType?  @map("block_reason")
  createdAt                 DateTime          @default(now()) @map("created_at")
  updatedAt                 DateTime          @updatedAt @map("updated_at")

  faculty                   Faculty           @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  head                      Staff?            @relation(fields: [headId], references: [userId], onDelete: SetNull)
  students                  Student[]
  programLevels             ProgramLevel[]
  programCourses            ProgramCourse[]
  programTranscriptDefs     ProgramTranscriptDefinition[]
  academicLoadSemesters     AcademicLoadSemester[]
  academicLoadGPAs          AcademicLoadGPA[]
  classSessions             ClassSession[]

  @@index([facultyId])
  @@index([programType])
  @@index([headId])
  @@map("Program")
}

// ============================================================================================================
// STUDENT
// ============================================================================================================

model Student {
  userId                    Int           @id @map("user_id")
  universityStudentId       Int           @unique @map("university_student_id")
  programId                 Int           @map("program_id")
  academicYear              String?       @map("academic_year") @db.VarChar(20)
  status                    StudentStatus @default(New)
  enrollmentDate            DateTime      @map("enrollment_date") @db.Date
  cgpa                      Decimal       @default(0.0000) @db.Decimal(5, 4)
  religion                  Boolean
  gender                    Boolean
  homePhone                 String?       @map("home_phone") @db.VarChar(20)
  previousQualification     String?       @map("previous_qualification") @db.VarChar(255)
  secondarySchoolName       String?       @map("secondary_school_name") @db.VarChar(255)
  totalHighSchoolGrades     Decimal?      @map("total_high_school_grades") @db.Decimal(5, 2)
  highSchoolSeatNumber      String?       @map("high_school_seat_number") @db.VarChar(50)

  user                      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  program                   Program       @relation(fields: [programId], references: [id], onDelete: Restrict)
  studentFeeReports         StudentFeeReport[]
  courseRegistrations      CourseRegistration[]
  transcripts              Transcript[]
  studentAttendances       StudentAttendance[]
  attendanceReports        AttendanceReport[]

  @@index([programId])
  @@index([status])
  @@index([universityStudentId])
  @@map("Student")
}

// ============================================================================================================
// REGULATION
// ============================================================================================================

model Regulation {
  id                       Int       @id @default(autoincrement())
  facultyId                Int       @map("faculty_id")
  name                     String    @db.VarChar(255)
  roundToWholeNumber       Boolean   @default(false) @map("round_to_whole_number")
  approximateFractions     Boolean   @default(false) @map("approximate_fractions")
  maxAbsence               Int       @default(0) @map("max_absence")
  minGradeExcellent        Decimal   @map("min_grade_excellent") @db.Decimal(5, 2)
  minGradeVeryGood         Decimal   @map("min_grade_very_good") @db.Decimal(5, 2)
  minGradeGood             Decimal   @map("min_grade_good") @db.Decimal(5, 2)
  minGradeAcceptable       Decimal   @map("min_grade_acceptable") @db.Decimal(5, 2)
  minGradeVeryWeak         Decimal   @map("min_grade_very_weak") @db.Decimal(5, 2)
  enableMercyRules         Boolean   @default(false) @map("enable_mercy_rules")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  faculty                  Faculty   @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  mercyRules               MercyRule[]

  @@index([facultyId])
  @@map("Regulation")
}

// ============================================================================================================
// MERCY RULE
// ============================================================================================================

model MercyRule {
  id                Int       @id @default(autoincrement())
  regulationId      Int       @map("regulation_id")
  originalScore     Decimal   @map("original_score") @db.Decimal(5, 2)
  adjustedScore     Decimal   @map("adjusted_score") @db.Decimal(5, 2)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  regulation        Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)

  @@index([regulationId])
  @@map("MercyRule")
}

// ============================================================================================================
// SEMESTER
// ============================================================================================================

model Semester {
  id              Int           @id @default(autoincrement())
  year            Int
  number          Int
  startDate       DateTime      @map("start_date") @db.Date
  endDate         DateTime      @map("end_date") @db.Date
  type            SemesterType

  fees                      Fee[]
  academicLoadSemesters     AcademicLoadSemester[]
  studentFeeReports         StudentFeeReport[]
  courseRegistrations       CourseRegistration[]
  transcripts               Transcript[]
  classSessions             ClassSession[]

  @@unique([year, number])
  @@index([year])
  @@map("Semester")
}

// ============================================================================================================
// PROGRAM LEVEL
// ============================================================================================================

model ProgramLevel {
  id              Int       @id @default(autoincrement())
  programId       Int       @map("program_id")
  level           Int
  minCredits      Int       @default(0) @map("min_credits")
  maxCredits      Int       @default(0) @map("max_credits")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  program                   Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  fees                      Fee[]
  academicLoadSemesters     AcademicLoadSemester[]
  studentFeeReports         StudentFeeReport[]

  @@unique([programId, level])
  @@index([programId])
  @@map("ProgramLevel")
}

// ============================================================================================================
// FEE
// ============================================================================================================

model Fee {
  id              Int       @id @default(autoincrement())
  programLevelId  Int       @map("program_level_id")
  semesterId      Int?      @map("semester_id")
  feeType         FeeType   @map("fee_type")
  amount          Decimal   @db.Decimal(12, 2)
  description     String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  programLevel            ProgramLevel      @relation(fields: [programLevelId], references: [id], onDelete: Cascade)
  semester                Semester?         @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  studentFeeReports       StudentFeeReport[]

  @@index([programLevelId])
  @@index([semesterId])
  @@index([feeType])
  @@map("Fee")
}

// ============================================================================================================
// PROGRAM TRANSCRIPT DEFINITION
// ============================================================================================================

model ProgramTranscriptDefinition {
  id                Int       @id @default(autoincrement())
  programId         Int       @map("program_id")
  gradeLetter       String    @map("grade_letter") @db.VarChar(10)
  minScore          Decimal   @map("min_score") @db.Decimal(5, 2)
  maxScore          Decimal   @map("max_score") @db.Decimal(5, 2)
  equivalentEstimate String?  @map("equivalent_estimate") @db.VarChar(20)
  minGpa            Decimal   @map("min_gpa") @db.Decimal(5, 4)
  maxGpa            Decimal   @map("max_gpa") @db.Decimal(5, 4)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  program           Program   @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, gradeLetter])
  @@index([programId])
  @@map("ProgramTranscriptDefinition")
}

// ============================================================================================================
// ACADEMIC LOAD SEMESTER
// ============================================================================================================

model AcademicLoadSemester {
  id              Int       @id @default(autoincrement())
  programId       Int       @map("program_id")
  semesterId      Int       @map("semester_id")
  programLevelId  Int       @map("program_level_id")
  minCredits      Int       @map("min_credits")
  maxCredits      Int       @map("max_credits")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  program         Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  semester        Semester  @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  programLevel    ProgramLevel @relation(fields: [programLevelId], references: [id], onDelete: Cascade)

  @@unique([programId, semesterId, programLevelId])
  @@index([programId])
  @@index([semesterId])
  @@map("AcademicLoadSemester")
}

// ============================================================================================================
// ACADEMIC LOAD GPA
// ============================================================================================================

model AcademicLoadGPA {
  id              Int       @id @default(autoincrement())
  programId       Int       @map("program_id")
  minGpa          Decimal   @map("min_gpa") @db.Decimal(5, 4)
  maxGpa          Decimal   @map("max_gpa") @db.Decimal(5, 4)
  minCredits      Int       @map("min_credits")
  maxCredits      Int       @map("max_credits")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  program         Program   @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
  @@map("AcademicLoadGPA")
}

// ============================================================================================================
// COURSE
// ============================================================================================================

model Course {
  id                          Int       @id @default(autoincrement())
  name                        String    @db.VarChar(255)
  code                        String    @unique @db.VarChar(20)
  description                 String?
  credits                     Int
  syllabus                    String?
  successPercentage           Decimal?  @map("success_percentage") @db.Decimal(5, 2)
  totalFail                   Boolean   @default(false) @map("total_fail")
  minFinalSuccessPercentage   Decimal?  @map("min_final_success_percentage") @db.Decimal(5, 2)
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")

  classSessions               ClassSession[]
  programCourses              ProgramCourse[]
  coursePrerequisitesFor      CoursePrerequisite[] @relation("course")
  coursePrerequisites         CoursePrerequisite[] @relation("prerequisite")
  attendanceReports           AttendanceReport[]

  @@index([code])
  @@map("Course")
}

// ============================================================================================================
// CLASSROOM
// ============================================================================================================

model Classroom {
  id              Int       @id @default(autoincrement())
  roomNumber      String    @map("room_number") @db.VarChar(50)
  building        String    @db.VarChar(100)
  capacity        Int
  type            ClassroomType
  isAvailable     Boolean   @default(true) @map("is_available")

  classSessions   ClassSession[]

  @@unique([roomNumber, building])
  @@index([building])
  @@index([isAvailable])
  @@map("Classroom")
}

// ============================================================================================================
// ROOM
// ============================================================================================================

model Room {
  id                      Int       @id @default(autoincrement())
  roomName                String    @map("room_name") @db.VarChar(255)
  description             String?
  createdBy               Int       @map("created_by")
  maxMembers              Int?      @map("max_members")
  accessCode              String?   @map("access_code") @db.VarChar(50)
  allowStudentPosts       Boolean   @default(false) @map("allow_student_posts")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  creator                 User      @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  members                 RoomMember[]
  posts                   RoomPost[]
  classSessions           ClassSession[]

  @@index([createdBy])
  @@index([accessCode])
  @@map("Room")
}

// ============================================================================================================
// CLASS SESSION
// ============================================================================================================

model ClassSession {
  id                      Int       @id @default(autoincrement())
  courseId                Int       @map("course_id")
  teacherId               Int       @map("teacher_id")
  programId               Int       @map("program_id")
  classroomId             Int       @map("classroom_id")
  semesterId              Int       @map("semester_id")
  roomId                  Int       @map("room_id")
  academicLevel           Int       @map("academic_level")
  dayOfWeek               DayOfWeek @map("day_of_week")
  startTime               DateTime  @map("start_time") @db.Time()
  endTime                 DateTime  @map("end_time") @db.Time()

  course                  Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher                 Staff     @relation(fields: [teacherId], references: [userId], onDelete: Restrict)
  program                 Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  classroom               Classroom @relation(fields: [classroomId], references: [id], onDelete: Restrict)
  semester                Semester  @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  room                    Room      @relation(fields: [roomId], references: [id], onDelete: Restrict)
  
  courseAssessments       CourseAssessment[]
  courseRegistrations     CourseRegistration[]
  attendanceSessions      AttendanceSession[]

  @@index([courseId])
  @@index([teacherId])
  @@index([programId])
  @@index([semesterId])
  @@index([dayOfWeek, startTime])
  @@map("ClassSession")
}

// ============================================================================================================
// COURSE ASSESSMENT
// ============================================================================================================

model CourseAssessment {
  id                      Int       @id @default(autoincrement())
  classSessionId          Int       @map("class_session_id")
  label                   String    @db.VarChar(100)
  assessmentType          CourseAssessmentType @map("assessment_type")
  marks                   Decimal   @db.Decimal(5, 2)
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  classSession            ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  grades                  Grade[]

  @@index([classSessionId])
  @@index([assessmentType])
  @@map("CourseAssessment")
}

// ============================================================================================================
// PROGRAM COURSE
// ============================================================================================================

model ProgramCourse {
  programId               Int       @map("program_id")
  courseId                Int       @map("course_id")
  type                    CourseType

  program                 Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  course                  Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([programId, courseId])
  @@index([courseId])
  @@index([type])
  @@map("ProgramCourse")
}

// ============================================================================================================
// COURSE PREREQUISITE
// ============================================================================================================

model CoursePrerequisite {
  courseId                Int       @map("course_id")
  prerequisiteId          Int       @map("prerequisite_id")

  course                  Course    @relation("course", fields: [courseId], references: [id], onDelete: Cascade)
  prerequisite            Course    @relation("prerequisite", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@id([courseId, prerequisiteId])
  @@index([prerequisiteId])
  @@map("CoursePrerequisite")
}

// ============================================================================================================
// STUDENT FEE REPORT
// ============================================================================================================

model StudentFeeReport {
  id                      Int       @id @default(autoincrement())
  studentId               Int       @map("student_id")
  programLevelId          Int       @map("program_level_id")
  semesterId              Int       @map("semester_id")
  feeId                   Int       @map("fee_id")
  amount                  Decimal   @db.Decimal(12, 2)
  status                  FeeStatus @default(Pending)
  generatedDate           DateTime  @default(now()) @map("generated_date") @db.Date
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  student                 Student   @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  programLevel            ProgramLevel @relation(fields: [programLevelId], references: [id], onDelete: Restrict)
  semester                Semester  @relation(fields: [semesterId], references: [id], onDelete: Restrict)
  fee                     Fee       @relation(fields: [feeId], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([semesterId])
  @@index([status])
  @@map("StudentFeeReport")
}

// ============================================================================================================
// ROLE
// ============================================================================================================

model Role {
  id                      Int       @id @default(autoincrement())
  name                    String    @unique @db.VarChar(100)
  description             String?
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  userRoles               UserRole[]
  permissions             RolePermission[]

  @@index([name])
  @@map("Role")
}

// ============================================================================================================
// PERMISSION
// ============================================================================================================

model Permission {
  id                      Int       @id @default(autoincrement())
  name                    String    @unique @db.VarChar(100)
  description             String?
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  rolePermissions         RolePermission[]

  @@index([name])
  @@map("Permission")
}

// ============================================================================================================
// USER ROLE
// ============================================================================================================

model UserRole {
  userId                  Int       @map("user_id")
  roleId                  Int       @map("role_id")
  assignedAt              DateTime  @default(now()) @map("assigned_at")

  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                    Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("UserRole")
}

// ============================================================================================================
// ROLE PERMISSION
// ============================================================================================================

model RolePermission {
  roleId                  Int       @map("role_id")
  permissionId            Int       @map("permission_id")

  role                    Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission              Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("RolePermission")
}

// ============================================================================================================
// COURSE REGISTRATION
// ============================================================================================================

model CourseRegistration {
  id                      Int       @id @default(autoincrement())
  studentId               Int       @map("student_id")
  sessionId               Int       @map("session_id")
  semesterId              Int       @map("semester_id")
  enrollmentDate          DateTime  @default(now()) @map("enrollment_date") @db.Date
  status                  RegistrationStatus @default(Enrolled)
  grade                   GradeEnum?
  gradePoints             Int?      @map("grade_points")

  student                 Student   @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  session                 ClassSession @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  semester                Semester  @relation(fields: [semesterId], references: [id], onDelete: Restrict)
  grades                  Grade[]

  @@unique([studentId, sessionId, semesterId])
  @@index([studentId])
  @@index([sessionId])
  @@index([semesterId])
  @@index([status])
  @@map("CourseRegistration")
}

// ============================================================================================================
// GRADE
// ============================================================================================================

model Grade {
  id                      Int       @id @default(autoincrement())
  courseRegistrationId    Int       @map("course_registration_id")
  courseAssessmentId      Int       @map("course_assessment_id")
  marks                   Decimal   @db.Decimal(5, 2)
  maxMarks                Decimal   @map("max_marks") @db.Decimal(5, 2)
  assessmentDate          DateTime? @map("assessment_date") @db.Date
  comments                String?

  courseRegistration     CourseRegistration @relation(fields: [courseRegistrationId], references: [id], onDelete: Cascade)
  courseAssessment       CourseAssessment @relation(fields: [courseAssessmentId], references: [id], onDelete: Cascade)

  @@index([courseRegistrationId])
  @@index([courseAssessmentId])
  @@map("Grade")
}

// ============================================================================================================
// TRANSCRIPT
// ============================================================================================================

model Transcript {
  id                      Int       @id @default(autoincrement())
  studentId               Int       @map("student_id")
  semesterId              Int       @map("semester_id")
  year                    Int
  semesterGpa             Decimal   @map("semester_gpa") @db.Decimal(5, 4)
  cumulativeGpa           Decimal   @map("cumulative_gpa") @db.Decimal(5, 4)
  totalCredits            Int       @default(0) @map("total_credits")
  generatedDate           DateTime  @default(now()) @map("generated_date") @db.Date

  student                 Student   @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  semester                Semester  @relation(fields: [semesterId], references: [id], onDelete: Restrict)

  @@unique([studentId, semesterId])
  @@index([studentId])
  @@index([semesterId])
  @@index([year])
  @@map("Transcript")
}

// ============================================================================================================
// ATTENDANCE SESSION
// ============================================================================================================

model AttendanceSession {
  id                      Int       @id @default(autoincrement())
  classSessionId          Int       @map("class_session_id")
  facultyMemberId         Int       @map("faculty_member_id")
  sessionDate             DateTime  @map("session_date") @db.Date
  startTime               DateTime  @map("start_time") @db.Time()
  endTime                 DateTime  @map("end_time") @db.Time()
  attendanceMode          AttendanceMode @map("attendance_mode")
  hotspotSsid             String?   @map("hotspot_ssid") @db.VarChar(255)
  qrCode                  String?   @map("qr_code") @db.VarChar(500)
  isActive                Boolean   @default(true) @map("is_active")
  createdAt               DateTime  @default(now()) @map("created_at")
  sessionNotes            String?   @map("session_notes")

  classSession            ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  facultyMember           Staff     @relation(fields: [facultyMemberId], references: [userId], onDelete: Restrict)
  studentAttendances      StudentAttendance[]

  @@index([classSessionId])
  @@index([sessionDate])
  @@index([facultyMemberId])
  @@index([isActive])
  @@map("AttendanceSession")
}

// ============================================================================================================
// STUDENT ATTENDANCE
// ============================================================================================================

model StudentAttendance {
  id                      Int       @id @default(autoincrement())
  attendanceSessionId     Int       @map("attendance_session_id")
  studentId               Int       @map("student_id")
  status                  AttendanceStatus
  recordedAt              DateTime  @default(now()) @map("recorded_at")
  deviceIp                String?   @map("device_ip") @db.Inet
  deviceMac String? @map("device_mac") @db.VarChar(17)
  notes                   String?
  isOfflineSync           Boolean   @default(false) @map("is_offline_sync")
  syncedAt                DateTime? @map("synced_at")

  attendanceSession       AttendanceSession @relation(fields: [attendanceSessionId], references: [id], onDelete: Cascade)
  student                 Student   @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@unique([attendanceSessionId, studentId])
  @@index([attendanceSessionId])
  @@index([studentId])
  @@index([status])
  @@index([recordedAt])
  @@map("StudentAttendance")
}

// ============================================================================================================
// ATTENDANCE REPORT
// ============================================================================================================

model AttendanceReport {
  id                      Int       @id @default(autoincrement())
  courseId                Int       @map("course_id")
  studentId               Int       @map("student_id")
  totalSessions           Int       @default(0) @map("total_sessions")
  attendedSessions        Int       @default(0) @map("attended_sessions")
  attendancePercentage    Decimal   @map("attendance_percentage") @db.Decimal(5, 2)
  reportPeriodStart       DateTime  @map("report_period_start") @db.Date
  reportPeriodEnd         DateTime  @map("report_period_end") @db.Date
  generatedAt             DateTime  @default(now()) @map("generated_at")

  course                  Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student                 Student   @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  @@unique([courseId, studentId, reportPeriodStart, reportPeriodEnd])
  @@index([courseId])
  @@index([studentId])
  @@index([reportPeriodStart, reportPeriodEnd])
  @@map("AttendanceReport")
}

// ============================================================================================================
// ROOM MEMBER
// ============================================================================================================

model RoomMember {
  id                      Int       @id @default(autoincrement())
  roomId                  Int       @map("room_id")
  userId                  Int       @map("user_id")
  role                    RoomRole  @default(Member)
  joinedAt                DateTime  @default(now()) @map("joined_at")

  room                    Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@map("RoomMember")
}

// ============================================================================================================
// ROOM POST
// ============================================================================================================

model RoomPost {
  id                      Int       @id @default(autoincrement())
  roomId                  Int       @map("room_id")
  authorId                Int       @map("author_id")
  content                 String?
  postType                PostType  @map("post_type")
  isPinned                Boolean   @default(false) @map("is_pinned")
  isEdited                Boolean   @default(false) @map("is_edited")
  dueDate                 DateTime? @map("due_date")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  room                    Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author                  User      @relation(fields: [authorId], references: [id], onDelete: Restrict)
  attachments             RoomPostAttachment[]
  comments                RoomPostComment[]

  @@index([roomId])
  @@index([authorId])
  @@index([createdAt])
  @@index([isPinned, roomId])
  @@map("RoomPost")
}

// ============================================================================================================
// ROOM POST ATTACHMENT
// ============================================================================================================

model RoomPostAttachment {
  id                      Int       @id @default(autoincrement())
  postId                  Int       @map("post_id")
  fileName                String    @map("file_name") @db.VarChar(255)
  fileType                String    @map("file_type") @db.VarChar(50)
  storageProvider         StorageProvider @map("storage_provider")
  storagePath             String    @map("storage_path") @db.VarChar(500)
  fileSize                BigInt?   @map("file_size")
  uploadedAt              DateTime  @default(now()) @map("uploaded_at")

  post                    RoomPost  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("RoomPostAttachment")
}

// ============================================================================================================
// ROOM POST COMMENT
// ============================================================================================================

model RoomPostComment {
  id                      Int       @id @default(autoincrement())
  postId                  Int       @map("post_id")
  authorId                Int       @map("author_id")
  content                 String
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  post                    RoomPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  author                  User      @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([postId])
  @@index([authorId])
  @@index([createdAt])
  @@map("RoomPostComment")
}